<?xml version="1.0" encoding="utf-8" ?>
<widget id="conventsystems.echartsgaugechart.EChartsGaugeChart" offlineCapable="true" pluginWidget="true"
        xmlns="http://www.mendix.com/widget/1.0/"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>ECharts Gauge chart</name>
    <description>Gauge / speedometer chart powered by Apache ECharts</description>
    <studioProCategory>Charts</studioProCategory>
    <studioCategory>Charts</studioCategory>
    <properties>
        <propertyGroup caption="General">
            <propertyGroup caption="Multi-needle (list)">
                <property key="useListMode" type="boolean" defaultValue="false">
                    <caption>Use list data source</caption>
                    <description>When enabled, the widget reads needles from a list data source instead of the surrounding Data View. Place the widget outside any Data View when using this mode.</description>
                </property>
                <property key="dataSource" type="datasource" isList="true" required="false">
                    <caption>Data source</caption>
                    <description>Optional list data source. When configured, every item becomes a needle in one shared gauge series. Overrides the Series 1/2/3 context attributes.</description>
                </property>
                <property key="listValueAttribute" type="attribute" dataSource="dataSource" required="false">
                    <caption>Value attribute</caption>
                    <description>Numeric attribute for the needle value.</description>
                    <attributeTypes>
                        <attributeType name="Decimal" />
                        <attributeType name="Integer" />
                        <attributeType name="Long" />
                        <attributeType name="AutoNumber" />
                    </attributeTypes>
                </property>
                <property key="listLabelAttribute" type="attribute" dataSource="dataSource" required="false">
                    <caption>Label attribute</caption>
                    <description>String attribute for the needle label shown below the needle tip.</description>
                    <attributeTypes>
                        <attributeType name="String" />
                        <attributeType name="Enum" />
                    </attributeTypes>
                </property>
                <property key="listCustomOptions" type="string" required="false" multiline="true">
                    <caption>Custom options (list series)</caption>
                    <description>JSON object merged into the shared ECharts series config when using the list data source, e.g. pointer style, progress, anchor.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Series 1">
                <property key="valueAttribute" type="attribute" required="false">
                    <caption>Value attribute</caption>
                    <description>Numeric attribute for the gauge reading. Read from the surrounding Data View context.</description>
                    <attributeTypes>
                        <attributeType name="Decimal" />
                        <attributeType name="Integer" />
                        <attributeType name="Long" />
                        <attributeType name="AutoNumber" />
                    </attributeTypes>
                </property>
                <property key="labelAttribute" type="textTemplate" required="false" multiline="false">
                    <caption>Label</caption>
                    <description>Label shown below the needle tip.</description>
                </property>
                <property key="series1CustomOptions" type="string" required="false" multiline="true">
                    <caption>Custom options (Series 1)</caption>
                    <description>JSON object merged into Series 1 ECharts config, e.g. pointer style.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Series 2">
                <property key="valueAttribute2" type="attribute" required="false">
                    <caption>Value attribute (Series 2)</caption>
                    <description>When set, a second gauge series is rendered. Leave empty for single-series mode.</description>
                    <attributeTypes>
                        <attributeType name="Decimal" />
                        <attributeType name="Integer" />
                        <attributeType name="Long" />
                        <attributeType name="AutoNumber" />
                    </attributeTypes>
                </property>
                <property key="labelAttribute2" type="textTemplate" required="false" multiline="false">
                    <caption>Label (Series 2)</caption>
                    <description>Label shown below the needle tip for Series 2.</description>
                </property>
                <property key="series2Min" type="integer" defaultValue="0">
                    <caption>Minimum (Series 2)</caption>
                    <description>Minimum value for Series 2 scale.</description>
                </property>
                <property key="series2Max" type="integer" defaultValue="100">
                    <caption>Maximum (Series 2)</caption>
                    <description>Maximum value for Series 2 scale.</description>
                </property>
                <property key="series2CustomOptions" type="string" required="false" multiline="true">
                    <caption>Custom options (Series 2)</caption>
                    <description>JSON object merged into Series 2 ECharts config, e.g. pointer style.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Series 3">
                <property key="valueAttribute3" type="attribute" required="false">
                    <caption>Value attribute (Series 3)</caption>
                    <description>When set, a third gauge series is rendered. Leave empty to skip.</description>
                    <attributeTypes>
                        <attributeType name="Decimal" />
                        <attributeType name="Integer" />
                        <attributeType name="Long" />
                        <attributeType name="AutoNumber" />
                    </attributeTypes>
                </property>
                <property key="labelAttribute3" type="textTemplate" required="false" multiline="false">
                    <caption>Label (Series 3)</caption>
                    <description>Label shown below the needle tip for Series 3.</description>
                </property>
                <property key="series3Min" type="integer" defaultValue="0">
                    <caption>Minimum (Series 3)</caption>
                    <description>Minimum value for Series 3 scale.</description>
                </property>
                <property key="series3Max" type="integer" defaultValue="100">
                    <caption>Maximum (Series 3)</caption>
                    <description>Maximum value for Series 3 scale.</description>
                </property>
                <property key="series3CustomOptions" type="string" required="false" multiline="true">
                    <caption>Custom options (Series 3)</caption>
                    <description>JSON object merged into Series 3 ECharts config, e.g. pointer style.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="General">
                <property key="enableAdvancedOptions" type="boolean" defaultValue="false">
                    <caption>Enable advanced options</caption>
                    <description />
                </property>
                <property key="min" type="integer" defaultValue="0">
                    <caption>Minimum</caption>
                    <description>Minimum value on the gauge scale (used as Series 1 minimum).</description>
                </property>
                <property key="max" type="integer" defaultValue="100">
                    <caption>Maximum</caption>
                    <description>Maximum value on the gauge scale (used as Series 1 maximum).</description>
                </property>
                <property key="units" type="string" required="false">
                    <caption>Units</caption>
                    <description>Suffix shown with the value, e.g. km/h or %.</description>
                </property>
                <property key="startAngle" type="integer" defaultValue="225">
                    <caption>Start angle</caption>
                    <description>Start of the gauge arc in degrees, counter-clockwise from 3 o'clock. Default: 225.</description>
                </property>
                <property key="endAngle" type="integer" defaultValue="-45">
                    <caption>End angle</caption>
                    <description>End of the gauge arc in degrees, counter-clockwise from 3 o'clock. Default: -45.</description>
                </property>
                <property key="splitNumber" type="integer" defaultValue="10">
                    <caption>Split number</caption>
                    <description>Number of major tick segments on the gauge arc.</description>
                </property>
                <property key="showProgress" type="boolean" defaultValue="true">
                    <caption>Show progress bar</caption>
                    <description>Fill the arc from the minimum to the current value.</description>
                </property>
                <property key="colorRanges" type="string" required="false" multiline="false">
                    <caption>Color ranges</caption>
                    <description>JSON array of [threshold, color] pairs where threshold is a fraction (0–1) of the full range. Example: [[0.3,"#67e0e3"],[0.7,"#37a2da"],[1,"#fd666d"]]</description>
                </property>
                <property key="showLegend" type="boolean" defaultValue="false">
                    <caption>Show legend</caption>
                    <description />
                </property>
                <property key="legendPosition" type="enumeration" defaultValue="top">
                    <caption>Legend position</caption>
                    <description />
                    <enumerationValues>
                        <enumerationValue key="top">Top</enumerationValue>
                        <enumerationValue key="bottom">Bottom</enumerationValue>
                        <enumerationValue key="left">Left</enumerationValue>
                        <enumerationValue key="right">Right</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="backgroundColor" type="string" required="false">
                    <caption>Background color</caption>
                    <description>CSS color for the chart background. Leave empty for transparent.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Visibility">
                <systemProperty key="Visibility" />
            </propertyGroup>
            <propertyGroup caption="Common">
                <systemProperty key="Name" />
                <systemProperty key="TabIndex" />
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Dimensions">
            <propertyGroup caption="Dimensions">
                <property key="widthUnit" type="enumeration" defaultValue="percentage">
                    <caption>Width unit</caption>
                    <description>Percentage: portion of parent size. Pixels: absolute amount of pixels.</description>
                    <enumerationValues>
                        <enumerationValue key="percentage">Percentage</enumerationValue>
                        <enumerationValue key="pixels">Pixels</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="width" type="integer" defaultValue="100">
                    <caption>Width</caption>
                    <description />
                </property>
                <property key="heightUnit" type="enumeration" defaultValue="percentageOfWidth">
                    <caption>Height unit</caption>
                    <description />
                    <enumerationValues>
                        <enumerationValue key="percentageOfWidth">Percentage of width</enumerationValue>
                        <enumerationValue key="pixels">Pixels</enumerationValue>
                        <enumerationValue key="percentageOfParent">Percentage of parent</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="height" type="integer" defaultValue="75">
                    <caption>Height</caption>
                    <description />
                </property>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Advanced">
            <propertyGroup caption="Advanced">
                <property key="customLayout" type="string" required="false" multiline="true">
                    <caption>Custom chart option</caption>
                    <description>JSON object deep-merged into the ECharts option.</description>
                </property>
                <property key="customConfigurations" type="string" required="false" multiline="true">
                    <caption>Custom init options</caption>
                    <description>JSON object passed to echarts.init() as the opts parameter.</description>
                </property>
            </propertyGroup>
        </propertyGroup>
    </properties>
</widget>
