<?xml version="1.0" encoding="utf-8" ?>
<widget id="conventsystems.echartslinechart.EChartsLineChart" offlineCapable="true" pluginWidget="true"
        xmlns="http://www.mendix.com/widget/1.0/"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>ECharts Line chart</name>
    <description>Line chart powered by Apache ECharts</description>
    <studioProCategory>Charts</studioProCategory>
    <studioCategory>Charts</studioCategory>
    <properties>
        <propertyGroup caption="General">
            <propertyGroup caption="Data source">
                <property key="lines" type="object" isList="true">
                    <caption>Series</caption>
                    <description>Add one or more lines. The order influences how lines overlay one another.</description>
                    <properties>
                        <propertyGroup caption="General">
                            <property key="dataSet" type="enumeration" defaultValue="static">
                                <caption>Data set</caption>
                                <description />
                                <enumerationValues>
                                    <enumerationValue key="static">Single series</enumerationValue>
                                    <enumerationValue key="dynamic">Multiple series</enumerationValue>
                                </enumerationValues>
                            </property>
                            <property key="staticDataSource" type="datasource" required="false" isList="true">
                                <caption>Data source</caption>
                                <description>Data points for a single line.</description>
                            </property>
                            <property key="dynamicDataSource" type="datasource" required="false" isList="true">
                                <caption>Data source</caption>
                                <description>Data points for all lines, divided into series based on the Group by attribute.</description>
                            </property>
                            <property key="groupByAttribute" type="attribute" required="false" dataSource="dynamicDataSource">
                                <caption>Group by</caption>
                                <description>Data points with the same group value form one line.</description>
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Boolean" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Enum" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                </attributeTypes>
                            </property>
                            <property key="staticName" type="textTemplate" required="false" multiline="false">
                                <caption>Series name</caption>
                                <description>The line name shown in the legend.</description>
                            </property>
                            <property key="dynamicName" type="textTemplate" required="false" multiline="false" dataSource="dynamicDataSource">
                                <caption>Series name</caption>
                                <description>The line name shown in the legend (evaluated per item).</description>
                            </property>
                            <property key="staticXAttribute" type="attribute" required="false" dataSource="staticDataSource">
                                <caption>X axis attribute</caption>
                                <description />
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Enum" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="dynamicXAttribute" type="attribute" required="false" dataSource="dynamicDataSource">
                                <caption>X axis attribute</caption>
                                <description />
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Enum" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="staticYAttribute" type="attribute" required="false" dataSource="staticDataSource">
                                <caption>Y axis attribute</caption>
                                <description />
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Enum" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="dynamicYAttribute" type="attribute" required="false" dataSource="dynamicDataSource">
                                <caption>Y axis attribute</caption>
                                <description />
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Enum" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="aggregationType" type="enumeration" defaultValue="none">
                                <caption>Aggregation function</caption>
                                <description>How to aggregate when multiple Y values exist for the same X value.</description>
                                <enumerationValues>
                                    <enumerationValue key="none">None</enumerationValue>
                                    <enumerationValue key="count">Count</enumerationValue>
                                    <enumerationValue key="sum">Sum</enumerationValue>
                                    <enumerationValue key="avg">Average</enumerationValue>
                                    <enumerationValue key="min">Minimum</enumerationValue>
                                    <enumerationValue key="max">Maximum</enumerationValue>
                                    <enumerationValue key="median">Median</enumerationValue>
                                    <enumerationValue key="mode">Mode</enumerationValue>
                                    <enumerationValue key="first">First</enumerationValue>
                                    <enumerationValue key="last">Last</enumerationValue>
                                </enumerationValues>
                            </property>
                            <property key="staticTooltipHoverText" type="textTemplate" required="false" multiline="false" dataSource="staticDataSource">
                                <caption>Tooltip hover text</caption>
                                <description />
                            </property>
                            <property key="dynamicTooltipHoverText" type="textTemplate" required="false" multiline="false" dataSource="dynamicDataSource">
                                <caption>Tooltip hover text</caption>
                                <description />
                            </property>
                        </propertyGroup>
                        <propertyGroup caption="Appearance">
                            <property key="interpolation" type="enumeration" defaultValue="linear">
                                <caption>Interpolation</caption>
                                <description />
                                <enumerationValues>
                                    <enumerationValue key="linear">Linear</enumerationValue>
                                    <enumerationValue key="spline">Curved</enumerationValue>
                                </enumerationValues>
                            </property>
                            <property key="lineStyle" type="enumeration" defaultValue="line">
                                <caption>Line style</caption>
                                <description />
                                <enumerationValues>
                                    <enumerationValue key="line">Line</enumerationValue>
                                    <enumerationValue key="lineWithMarkers">Line with markers</enumerationValue>
                                    <enumerationValue key="custom">Custom</enumerationValue>
                                </enumerationValues>
                            </property>
                            <property key="staticLineColor" type="expression" required="false" dataSource="staticDataSource">
                                <caption>Line color</caption>
                                <description>CSS color value, e.g. #FF0000 or red</description>
                                <returnType type="String" />
                            </property>
                            <property key="dynamicLineColor" type="expression" required="false" dataSource="dynamicDataSource">
                                <caption>Line color</caption>
                                <description>CSS color value, e.g. #FF0000 or red</description>
                                <returnType type="String" />
                            </property>
                            <property key="staticMarkerColor" type="expression" required="false" dataSource="staticDataSource">
                                <caption>Marker color</caption>
                                <description>CSS color value for data point markers</description>
                                <returnType type="String" />
                            </property>
                            <property key="dynamicMarkerColor" type="expression" required="false" dataSource="dynamicDataSource">
                                <caption>Marker color</caption>
                                <description>CSS color value for data point markers</description>
                                <returnType type="String" />
                            </property>
                            <property key="fillArea" type="boolean" defaultValue="false">
                                <caption>Fill area</caption>
                                <description>Fill the area below the line to create an area chart.</description>
                            </property>
                        </propertyGroup>
                        <propertyGroup caption="Events">
                            <property key="staticOnClickAction" type="action" required="false" dataSource="staticDataSource">
                                <caption>On click action</caption>
                                <description />
                            </property>
                            <property key="dynamicOnClickAction" type="action" required="false" dataSource="dynamicDataSource">
                                <caption>On click action</caption>
                                <description />
                            </property>
                        </propertyGroup>
                        <propertyGroup caption="Timeline">
                            <property key="staticTimelineAttribute" type="attribute" required="false" dataSource="staticDataSource">
                                <caption>Timeline attribute</caption>
                                <description>Group data into timeline steps by this attribute. Each unique value becomes one timeline step.</description>
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Boolean" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Enum" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="dynamicTimelineAttribute" type="attribute" required="false" dataSource="dynamicDataSource">
                                <caption>Timeline attribute</caption>
                                <description>Group data into timeline steps by this attribute. Each unique value becomes one timeline step.</description>
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Boolean" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Enum" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                        </propertyGroup>
                        <propertyGroup caption="Advanced">
                            <property key="customSeriesOptions" type="string" required="false" multiline="true">
                                <caption>Custom series options</caption>
                                <description>JSON object merged into this series' ECharts series config. Only applied when Line style is set to Custom.</description>
                            </property>
                        </propertyGroup>
                    </properties>
                </property>
            </propertyGroup>
            <propertyGroup caption="General">
                <property key="enableAdvancedOptions" type="boolean" defaultValue="false">
                    <caption>Enable advanced options</caption>
                    <description />
                </property>
                <property key="xAxisLabel" type="textTemplate" required="false" multiline="false">
                    <caption>X axis label</caption>
                    <description />
                </property>
                <property key="xAxisDateFormat" type="string" required="false">
                    <caption>X axis date format</caption>
                    <description>Format for DateTime X axis values. Tokens: yyyy yy MM dd HH mm ss. Example: dd-MM-yyyy or MM/dd/yyyy or dd-MM HH:mm</description>
                </property>
                <property key="yAxisLabel" type="textTemplate" required="false" multiline="false">
                    <caption>Y axis label</caption>
                    <description />
                </property>
                <property key="showLegend" type="boolean" defaultValue="true">
                    <caption>Show legend</caption>
                    <description />
                </property>
                <property key="legendPosition" type="enumeration" defaultValue="top">
                    <caption>Legend position</caption>
                    <description />
                    <enumerationValues>
                        <enumerationValue key="top">Top</enumerationValue>
                        <enumerationValue key="bottom">Bottom</enumerationValue>
                        <enumerationValue key="left">Left</enumerationValue>
                        <enumerationValue key="right">Right</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="gridLines" type="enumeration" defaultValue="none">
                    <caption>Grid lines</caption>
                    <description />
                    <enumerationValues>
                        <enumerationValue key="none">None</enumerationValue>
                        <enumerationValue key="horizontal">Horizontal</enumerationValue>
                        <enumerationValue key="vertical">Vertical</enumerationValue>
                        <enumerationValue key="both">Both</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="backgroundColor" type="string" required="false">
                    <caption>Background color</caption>
                    <description>CSS color for the chart background, e.g. #ffffff or rgba(255,255,255,0.5). Leave empty for transparent.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Timeline">
                <property key="enableTimeline" type="boolean" defaultValue="false">
                    <caption>Enable timeline</caption>
                    <description>Show an ECharts timeline control. Set a Timeline attribute on each series to define the steps.</description>
                </property>
                <property key="timelineDateFormat" type="string" required="false">
                    <caption>Timeline date format</caption>
                    <description>Format for DateTime timeline step labels. Tokens: yyyy yy MM dd HH mm ss. Example: dd-MM-yyyy</description>
                </property>
                <property key="timelineAutoPlay" type="boolean" defaultValue="false">
                    <caption>Auto play</caption>
                    <description />
                </property>
                <property key="timelineLoop" type="boolean" defaultValue="true">
                    <caption>Loop</caption>
                    <description />
                </property>
                <property key="timelinePlayInterval" type="integer" defaultValue="2000">
                    <caption>Play interval (ms)</caption>
                    <description />
                </property>
                <property key="timelineRewind" type="boolean" defaultValue="false">
                    <caption>Show rewind button</caption>
                    <description />
                </property>
            </propertyGroup>
            <propertyGroup caption="Visibility">
                <systemProperty key="Visibility" />
            </propertyGroup>
            <propertyGroup caption="Common">
                <systemProperty key="Name" />
                <systemProperty key="TabIndex" />
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Dimensions">
            <propertyGroup caption="Dimensions">
                <property key="widthUnit" type="enumeration" defaultValue="percentage">
                    <caption>Width unit</caption>
                    <description>Percentage: portion of parent size. Pixels: absolute amount of pixels.</description>
                    <enumerationValues>
                        <enumerationValue key="percentage">Percentage</enumerationValue>
                        <enumerationValue key="pixels">Pixels</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="width" type="integer" defaultValue="100">
                    <caption>Width</caption>
                    <description />
                </property>
                <property key="heightUnit" type="enumeration" defaultValue="percentageOfWidth">
                    <caption>Height unit</caption>
                    <description />
                    <enumerationValues>
                        <enumerationValue key="percentageOfWidth">Percentage of width</enumerationValue>
                        <enumerationValue key="pixels">Pixels</enumerationValue>
                        <enumerationValue key="percentageOfParent">Percentage of parent</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="height" type="integer" defaultValue="75">
                    <caption>Height</caption>
                    <description />
                </property>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Advanced">
            <propertyGroup caption="Advanced">
                <property key="customLayout" type="string" required="false" multiline="true">
                    <caption>Custom chart option</caption>
                    <description>JSON object deep-merged into the ECharts option. Use this to override any chart configuration.</description>
                </property>
                <property key="customConfigurations" type="string" required="false" multiline="true">
                    <caption>Custom init options</caption>
                    <description>JSON object passed to echarts.init() as the opts parameter.</description>
                </property>
            </propertyGroup>
        </propertyGroup>
    </properties>
</widget>
