<?xml version="1.0" encoding="utf-8" ?>
<widget id="conventsystems.echartspiechart.EChartsPieChart" offlineCapable="true" pluginWidget="true"
        xmlns="http://www.mendix.com/widget/1.0/"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>ECharts Pie / Donut chart</name>
    <description>Pie and donut chart powered by Apache ECharts</description>
    <studioProCategory>Charts</studioProCategory>
    <studioCategory>Charts</studioCategory>
    <properties>
        <propertyGroup caption="General">
            <propertyGroup caption="Data source">
                <property key="series" type="object" isList="true">
                    <caption>Series</caption>
                    <description>Add one or more pie rings.</description>
                    <properties>
                        <propertyGroup caption="General">
                            <property key="dataSet" type="enumeration" defaultValue="static">
                                <caption>Data set</caption>
                                <description />
                                <enumerationValues>
                                    <enumerationValue key="static">Single ring</enumerationValue>
                                    <enumerationValue key="dynamic">Multiple rings</enumerationValue>
                                </enumerationValues>
                            </property>
                            <property key="staticDataSource" type="datasource" required="false" isList="true">
                                <caption>Data source</caption>
                                <description>Each record becomes one slice.</description>
                            </property>
                            <property key="dynamicDataSource" type="datasource" required="false" isList="true">
                                <caption>Data source</caption>
                                <description>Records grouped by the Group by attribute; each group becomes a concentric ring.</description>
                            </property>
                            <property key="groupByAttribute" type="attribute" required="false" dataSource="dynamicDataSource">
                                <caption>Group by</caption>
                                <description>Records with the same value form one ring.</description>
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Boolean" />
                                    <attributeType name="DateTime" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="Enum" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                </attributeTypes>
                            </property>
                            <property key="staticName" type="textTemplate" required="false" multiline="false">
                                <caption>Ring name</caption>
                                <description>Label for this ring (shown in legend for multi-ring charts).</description>
                            </property>
                            <property key="staticNameAttribute" type="attribute" required="false" dataSource="staticDataSource">
                                <caption>Slice label attribute</caption>
                                <description>Attribute whose value is the slice label.</description>
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Enum" />
                                    <attributeType name="Boolean" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="dynamicNameAttribute" type="attribute" required="false" dataSource="dynamicDataSource">
                                <caption>Slice label attribute</caption>
                                <description>Attribute whose value is the slice label within each ring.</description>
                                <attributeTypes>
                                    <attributeType name="String" />
                                    <attributeType name="Enum" />
                                    <attributeType name="Boolean" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="Decimal" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="staticValueAttribute" type="attribute" required="false" dataSource="staticDataSource">
                                <caption>Value attribute</caption>
                                <description>Numeric attribute that determines the slice size.</description>
                                <attributeTypes>
                                    <attributeType name="Decimal" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="dynamicValueAttribute" type="attribute" required="false" dataSource="dynamicDataSource">
                                <caption>Value attribute</caption>
                                <description>Numeric attribute that determines the slice size.</description>
                                <attributeTypes>
                                    <attributeType name="Decimal" />
                                    <attributeType name="Integer" />
                                    <attributeType name="Long" />
                                    <attributeType name="AutoNumber" />
                                </attributeTypes>
                            </property>
                            <property key="aggregationType" type="enumeration" defaultValue="sum">
                                <caption>Aggregation function</caption>
                                <description>How to combine records that share the same slice label.</description>
                                <enumerationValues>
                                    <enumerationValue key="none">None</enumerationValue>
                                    <enumerationValue key="count">Count</enumerationValue>
                                    <enumerationValue key="sum">Sum</enumerationValue>
                                    <enumerationValue key="avg">Average</enumerationValue>
                                    <enumerationValue key="min">Minimum</enumerationValue>
                                    <enumerationValue key="max">Maximum</enumerationValue>
                                    <enumerationValue key="median">Median</enumerationValue>
                                    <enumerationValue key="mode">Mode</enumerationValue>
                                    <enumerationValue key="first">First</enumerationValue>
                                    <enumerationValue key="last">Last</enumerationValue>
                                </enumerationValues>
                            </property>
                            <property key="staticTooltipHoverText" type="textTemplate" required="false" multiline="false" dataSource="staticDataSource">
                                <caption>Tooltip hover text</caption>
                                <description />
                            </property>
                            <property key="dynamicTooltipHoverText" type="textTemplate" required="false" multiline="false" dataSource="dynamicDataSource">
                                <caption>Tooltip hover text</caption>
                                <description />
                            </property>
                        </propertyGroup>
                        <propertyGroup caption="Appearance">
                            <property key="staticSliceColor" type="expression" required="false" dataSource="staticDataSource">
                                <caption>Slice color</caption>
                                <description>CSS color value, e.g. #FF0000 or red</description>
                                <returnType type="String" />
                            </property>
                            <property key="dynamicSliceColor" type="expression" required="false" dataSource="dynamicDataSource">
                                <caption>Slice color</caption>
                                <description>CSS color value, e.g. #FF0000 or red</description>
                                <returnType type="String" />
                            </property>
                        </propertyGroup>
                        <propertyGroup caption="Events">
                            <property key="staticOnClickAction" type="action" required="false" dataSource="staticDataSource">
                                <caption>On click action</caption>
                                <description />
                            </property>
                            <property key="dynamicOnClickAction" type="action" required="false" dataSource="dynamicDataSource">
                                <caption>On click action</caption>
                                <description />
                            </property>
                        </propertyGroup>
                        <propertyGroup caption="Advanced">
                            <property key="customSeriesOptions" type="string" required="false" multiline="true">
                                <caption>Custom series options</caption>
                                <description>JSON object merged into this ring's ECharts series config.</description>
                            </property>
                        </propertyGroup>
                    </properties>
                </property>
            </propertyGroup>
            <propertyGroup caption="General">
                <property key="enableAdvancedOptions" type="boolean" defaultValue="false">
                    <caption>Enable advanced options</caption>
                    <description />
                </property>
                <property key="donut" type="boolean" defaultValue="false">
                    <caption>Donut</caption>
                    <description>Show as a donut chart with a hollow centre.</description>
                </property>
                <property key="innerRadius" type="string" required="false">
                    <caption>Inner radius</caption>
                    <description>Size of the donut hole as a percentage, e.g. 40%. Default: 40%.</description>
                </property>
                <property key="outerRadius" type="string" required="false">
                    <caption>Outer radius</caption>
                    <description>Outer size of the chart as a percentage, e.g. 70%. Default: 70%.</description>
                </property>
                <property key="roseType" type="boolean" defaultValue="false">
                    <caption>Rose / Nightingale</caption>
                    <description>Vary the radius of each slice to also encode the value (Nightingale rose chart).</description>
                </property>
                <property key="showLegend" type="boolean" defaultValue="true">
                    <caption>Show legend</caption>
                    <description />
                </property>
                <property key="legendPosition" type="enumeration" defaultValue="top">
                    <caption>Legend position</caption>
                    <description />
                    <enumerationValues>
                        <enumerationValue key="top">Top</enumerationValue>
                        <enumerationValue key="bottom">Bottom</enumerationValue>
                        <enumerationValue key="left">Left</enumerationValue>
                        <enumerationValue key="right">Right</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="showToolbox" type="boolean" defaultValue="false">
                    <caption>Show toolbox</caption>
                    <description>Shows the default toolbox (data view, restore, save as image). For a custom toolbox use the Custom chart option field, e.g.: {"toolbox":{"feature":{"saveAsImage":{"show":true}}}}</description>
                </property>
                <property key="backgroundColor" type="string" required="false">
                    <caption>Background color</caption>
                    <description>CSS color for the chart background. Leave empty for transparent.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Visibility">
                <systemProperty key="Visibility" />
            </propertyGroup>
            <propertyGroup caption="Common">
                <systemProperty key="Name" />
                <systemProperty key="TabIndex" />
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Dimensions">
            <propertyGroup caption="Dimensions">
                <property key="widthUnit" type="enumeration" defaultValue="percentage">
                    <caption>Width unit</caption>
                    <description>Percentage: portion of parent size. Pixels: absolute amount of pixels.</description>
                    <enumerationValues>
                        <enumerationValue key="percentage">Percentage</enumerationValue>
                        <enumerationValue key="pixels">Pixels</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="width" type="integer" defaultValue="100">
                    <caption>Width</caption>
                    <description />
                </property>
                <property key="heightUnit" type="enumeration" defaultValue="percentageOfWidth">
                    <caption>Height unit</caption>
                    <description />
                    <enumerationValues>
                        <enumerationValue key="percentageOfWidth">Percentage of width</enumerationValue>
                        <enumerationValue key="pixels">Pixels</enumerationValue>
                        <enumerationValue key="percentageOfParent">Percentage of parent</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="height" type="integer" defaultValue="75">
                    <caption>Height</caption>
                    <description />
                </property>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Advanced">
            <propertyGroup caption="Advanced">
                <property key="themeName" type="string" required="false">
                    <caption>Theme name</caption>
                    <description>Name of an ECharts theme registered via echarts.registerTheme(). Leave empty to use the ECharts default.</description>
                </property>
                <property key="customLayout" type="string" required="false" multiline="true">
                    <caption>Custom chart option</caption>
                    <description>JSON object deep-merged into the ECharts option.</description>
                </property>
                <property key="customConfigurations" type="string" required="false" multiline="true">
                    <caption>Custom init options</caption>
                    <description>JSON object passed to echarts.init() as the opts parameter.</description>
                </property>
            </propertyGroup>
        </propertyGroup>
    </properties>
</widget>
